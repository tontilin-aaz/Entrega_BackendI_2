{{!-- src/views/productDetail.handlebars --}}
<div class="product-detail-container">
    <a href="/products" class="back-link">
        <i class="fas fa-arrow-left"></i> Volver a productos
    </a>
    
    <div class="product-detail-card">
        <div class="product-detail-image">
            <i class="fas fa-box-open" style="font-size: 120px; color: #667eea;"></i>
        </div>
        
        <div class="product-detail-info">
            <h1 class="product-detail-title">{{product.title}}</h1>
            
            <div class="product-detail-meta">
                <span class="product-detail-category">{{product.category}}</span>
                <span class="product-detail-code">Código: {{product.code}}</span>
            </div>
            
            <div class="product-detail-price">
                ${{product.price}}
            </div>
            
            <div class="product-detail-description">
                <h3>Descripción:</h3>
                <p>{{product.description}}</p>
            </div>
            
            <div class="product-detail-stock">
                <strong>Stock disponible:</strong> {{product.stock}} unidades
            </div>
            
            <div class="product-detail-status">
                {{#if product.status}}
                    <span class="status-badge status-available">
                        <i class="fas fa-check-circle"></i> Producto disponible
                    </span>
                {{else}}
                    <span class="status-badge status-unavailable">
                        <i class="fas fa-times-circle"></i> Producto no disponible
                    </span>
                {{/if}}
            </div>
            
            <div class="product-detail-actions">
                <button onclick="addToCart('{{product.id}}')" class="btn-add-to-cart" {{#unless product.status}}disabled{{/unless}}>
                    <i class="fas fa-cart-plus"></i> Agregar al carrito
                </button>
            </div>
        </div>
    </div>
</div>

<script>
// Función para obtener o crear un carrito usando localStorage
async function getOrCreateCart() {
    let cartId = localStorage.getItem('cartId');
    
    // Si no hay carrito en localStorage, crear uno nuevo
    if (!cartId) {
        try {
            const response = await fetch('/api/carts', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                }
            });
            const data = await response.json();
            
            if (data.status === 'success' && data.data && data.data.id) {
                cartId = data.data.id;
                localStorage.setItem('cartId', cartId);
                console.log('✅ Carrito creado con ID:', cartId);
                
                // Actualizar el enlace del carrito en el header si existe
                updateCartLink(cartId);
            } else {
                throw new Error('No se pudo crear el carrito');
            }
        } catch (error) {
            console.error('❌ Error al crear carrito:', error);
            return null;
        }
    }
    
    return cartId;
}

// Función para actualizar el enlace del carrito en el header
function updateCartLink(cartId) {
    const cartLink = document.querySelector('a[href*="/carts/"]');
    if (cartLink) {
        cartLink.href = `/carts/${cartId}`;
    }
}

// Función para agregar producto al carrito
async function addToCart(productId) {
    const button = event.target;
    const originalText = button.innerHTML;
    
    // Mostrar estado de carga
    button.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Agregando...';
    button.disabled = true;
    
    try {
        const cartId = await getOrCreateCart();
        
        if (!cartId) {
            throw new Error('No se pudo obtener/crear el carrito');
        }
        
        const response = await fetch(`/api/carts/${cartId}/product/${productId}`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            }
        });
        
        const data = await response.json();
        
        if (data.status === 'success') {
            // Mostrar éxito temporalmente
            button.innerHTML = '<i class="fas fa-check"></i> Agregado';
            button.style.background = '#48bb78';
            
            setTimeout(() => {
                button.innerHTML = originalText;
                button.style.background = '';
                button.disabled = false;
            }, 2000);
            
            // Opcional: preguntar si quiere ir al carrito
            setTimeout(() => {
                if (confirm('✅ Producto agregado. ¿Quieres ver tu carrito?')) {
                    window.location.href = `/carts/${cartId}`;
                }
            }, 500);
        } else {
            throw new Error(data.message || 'Error al agregar producto');
        }
    } catch (error) {
        console.error('❌ Error:', error);
        button.innerHTML = '<i class="fas fa-exclamation-triangle"></i> Error';
        button.style.background = '#f56565';
        
        setTimeout(() => {
            button.innerHTML = originalText;
            button.style.background = '';
            button.disabled = false;
        }, 2000);
        
        alert('❌ Error al agregar al carrito: ' + error.message);
    }
}

// Inicializar al cargar la página
document.addEventListener('DOMContentLoaded', async () => {
    // Intentar obtener carrito existente o crear uno nuevo
    const cartId = await getOrCreateCart();
    if (cartId) {
        console.log('🛒 Carrito activo:', cartId);
    }
});
</script>

<style>
