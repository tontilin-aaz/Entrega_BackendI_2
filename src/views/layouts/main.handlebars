<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Arial', sans-serif;
        }
        
        body {
            background-color: #f5f5f5;
            color: #333;
            line-height: 1.6;
        }
        
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }
        
        header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 20px 0;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }
        
        .header-content {
            display: flex;
            justify-content: space-between;
            align-items: center;
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }
        
        h1 {
            font-size: 2rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        nav ul {
            display: flex;
            list-style: none;
            gap: 20px;
        }
        
        nav a {
            color: white;
            text-decoration: none;
            padding: 8px 16px;
            border-radius: 4px;
            transition: background-color 0.3s;
        }
        
        nav a:hover {
            background-color: rgba(255,255,255,0.2);
        }
        
        .products-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 25px;
            margin-top: 30px;
        }
        
        .product-card {
            background: white;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            transition: transform 0.3s, box-shadow 0.3s;
        }
        
        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.15);
        }
        
        .product-image {
            height: 200px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 48px;
        }
        
        .product-info {
            padding: 20px;
        }
        
        .product-title {
            font-size: 1.2rem;
            font-weight: bold;
            margin-bottom: 10px;
            color: #333;
        }
        
        .product-description {
            color: #666;
            margin-bottom: 15px;
            font-size: 0.9rem;
        }
        
        .product-details {
            display: flex;
            justify-content: space-between;
            margin-bottom: 15px;
        }
        
        .price {
            font-size: 1.3rem;
            font-weight: bold;
            color: #667eea;
        }
        
        .stock {
            color: #666;
            font-size: 0.9rem;
        }
        
        .category {
            display: inline-block;
            background: #e0e7ff;
            color: #667eea;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.8rem;
            margin-bottom: 15px;
        }
        
        .no-products {
            text-align: center;
            padding: 50px;
            color: #666;
            font-size: 1.1rem;
        }
        
        .form-container {
            background: white;
            padding: 30px;
            border-radius: 10px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            max-width: 600px;
            margin: 30px auto;
        }
        
        .form-group {
            margin-bottom: 20px;
        }
        
        label {
            display: block;
            margin-bottom: 5px;
            font-weight: bold;
            color: #333;
        }
        
        input, select, textarea {
            width: 100%;
            padding: 10px;
            border: 1px solid #ddd;
            border-radius: 4px;
            font-size: 1rem;
        }
        
        button {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 1rem;
            transition: opacity 0.3s;
        }
        
        button:hover {
            opacity: 0.9;
        }
        
        .delete-btn {
            background: linear-gradient(135deg, #f56565 0%, #ed64a6 100%);
        }
        
        footer {
            text-align: center;
            padding: 20px;
            margin-top: 40px;
            color: #666;
            border-top: 1px solid #ddd;
        }
        
        .socket-status {
            background: white;
            padding: 15px;
            border-radius: 4px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .status-connected {
            color: #48bb78;
        }
        
        .status-disconnected {
            color: #f56565;
        }

        /* Estilo para el contador del carrito */
        .cart-badge {
            background-color: #f56565;
            color: white;
            border-radius: 50%;
            padding: 2px 6px;
            font-size: 12px;
            margin-left: 5px;
            display: inline-block;
        }
    </style>
</head>
<body>
    <header>
        <div class="header-content">
            <h1><i class="fas fa-store"></i> Tienda Online</h1>
            <nav>
                <ul>
                    <li><a href="/"><i class="fas fa-home"></i> Inicio</a></li>
                    <li><a href="/products"><i class="fas fa-boxes"></i> Productos</a></li>
                    <li><a href="/realtimeproducts"><i class="fas fa-bolt"></i> Tiempo Real</a></li>
                    <li>
                        <a href="/carts/1" id="cart-link">
                            <i class="fas fa-shopping-cart"></i> Carrito 
                            <span id="cart-count" class="cart-badge" style="display: none;">0</span>
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
    </header>
    
    <main class="container">
        {{{body}}}
    </main>
    
    <footer>
        <p>&copy; 2024 Tienda Online - Entrega Backend</p>
    </footer>

    <script>
        // Función para obtener o crear un carrito usando localStorage
        async function getOrCreateCart() {
            let cartId = localStorage.getItem('cartId');
            
            // Si no hay carrito en localStorage, crear uno nuevo
            if (!cartId) {
                try {
                    const response = await fetch('/api/carts', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        }
                    });
                    const data = await response.json();
                    
                    if (data.status === 'success' && data.data && data.data.id) {
                        cartId = data.data.id;
                        localStorage.setItem('cartId', cartId);
                        console.log('✅ Carrito creado con ID:', cartId);
                    } else {
                        throw new Error('No se pudo crear el carrito');
                    }
                } catch (error) {
                    console.error('❌ Error al crear carrito:', error);
                    return null;
                }
            }
            
            return cartId;
        }

        // Función para obtener el conteo de productos del carrito
        async function getCartCount(cartId) {
            try {
                const response = await fetch(`/api/carts/${cartId}`);
                const data = await response.json();
                
                if (data.status === 'success' && data.data) {
                    return data.data.products ? data.data.products.length : 0;
                }
                return 0;
            } catch (error) {
                console.error('❌ Error al obtener conteo del carrito:', error);
                return 0;
            }
        }

        // Función para actualizar el enlace del carrito y el contador
        async function updateCartLink() {
            const cartLink = document.getElementById('cart-link');
            const cartCount = document.getElementById('cart-count');
            
            if (!cartLink) return;
            
            const cartId = await getOrCreateCart();
            
            if (cartId) {
                // Actualizar el href del enlace
                cartLink.href = `/carts/${cartId}`;
                
                // Obtener y mostrar el conteo de productos
                const count = await getCartCount(cartId);
                if (count > 0) {
                    cartCount.textContent = count;
                    cartCount.style.display = 'inline-block';
                } else {
                    cartCount.style.display = 'none';
                }
            }
        }

        // Ejecutar cuando la página cargue
        document.addEventListener('DOMContentLoaded', updateCartLink);

        // Escuchar eventos personalizados para actualizar el contador
        window.addEventListener('cartUpdated', function() {
            updateCartLink();
        });

        // También podemos exponer la función globalmente para que otras vistas puedan llamarla
        window.refreshCartCount = updateCartLink;
    </script>
</body>
</html>