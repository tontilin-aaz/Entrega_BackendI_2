    padding: 20px;
    display: grid;
    grid-template-columns: 80px 1fr 300px;
    gap: 20px;
    align-items: center;
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
}

.item-image {
    width: 80px;
    height: 80px;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 32px;
}

.item-info {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.item-title {
    margin: 0;
