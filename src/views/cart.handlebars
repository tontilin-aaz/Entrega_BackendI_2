    color: #666;
    font-size: 14px;
    margin: 0;
}

.item-category {
    background: #e0e7ff;
    color: #667eea;
    padding: 3px 10px;
    border-radius: 15px;
    font-size: 12px;
    align-self: flex-start;
}

.item-details {
    display: flex;
    flex-direction: column;
    gap: 10px;
}

