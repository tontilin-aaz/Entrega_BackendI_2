{{!-- src/views/cart.handlebars --}}
<div class="cart-container">
    <h1><i class="fas fa-shopping-cart"></i> Carrito de Compras</h1>
    
    <div class="cart-header">
        <span class="cart-id">ID del carrito: {{cart.id}}</span>
        <button onclick="clearCart()" class="btn-clear">
            <i class="fas fa-trash-alt"></i> Vaciar carrito
        </button>
    </div>
    
    {{#if cart.products.length}}
        <div class="cart-items">
            {{#each cart.products}}
            <div class="cart-item" id="cart-item-{{this.product.id}}">
                <div class="item-image">
                    <i class="fas fa-box"></i>
                </div>
                
                <div class="item-info">
                    <h3 class="item-title">{{this.product.title}}</h3>
                    <p class="item-description">{{this.product.description}}</p>
                    <span class="item-category">{{this.product.category}}</span>
                </div>
                
                <div class="item-details">
                    <div class="item-price">${{this.product.price}} c/u</div>
                    
                    <div class="item-quantity">
                        <label>Cantidad:</label>
                        <input 
                            type="number" 
                            min="1" 
                            value="{{this.quantity}}"
                            onchange="updateQuantity('{{this.product.id}}', this.value)"
                            class="quantity-input"
                        >
                    </div>
                    
                    <div class="item-subtotal">
                        Subtotal: ${{multiply this.product.price this.quantity}}
                    </div>
                    
                    <button onclick="removeFromCart('{{this.product.id}}')" class="btn-remove">
                        <i class="fas fa-trash"></i> Eliminar
                    </button>
                </div>
            </div>
            {{/each}}
        </div>
        
        <div class="cart-summary">
            <h3>Resumen de compra</h3>
            
            {{#each cart.products}}
            <div class="summary-item">
                <span>{{this.product.title}} x{{this.quantity}}</span>
                <span>${{multiply this.product.price this.quantity}}</span>
            </div>
            {{/each}}
            
            <div class="summary-total">
                <span>Total</span>
                <span class="total-amount">${{cartTotal cart.products}}</span>
            </div>
            
            <button class="btn-checkout">
                <i class="fas fa-credit-card"></i> Proceder al pago
            </button>
        </div>
    {{else}}
        <div class="empty-cart">
            <i class="fas fa-shopping-cart" style="font-size: 64px; color: #ccc;"></i>
            <h2>Tu carrito está vacío</h2>
            <p>¿No sabes qué comprar? ¡Miles de productos te esperan!</p>
            <a href="/products" class="btn-shop">
                <i class="fas fa-store"></i> Ir a la tienda
            </a>
        </div>
    {{/if}}
</div>

<script>
function updateQuantity(productId, newQuantity) {
    if (newQuantity < 1) {
        alert('La cantidad debe ser mayor a 0');
        return;
    }
    
    fetch(`/api/carts/{{cart.id}}/products/${productId}`, {
        method: 'PUT',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({ quantity: parseInt(newQuantity) })
    })
    .then(response => response.json())
    .then(data => {
        if (data.status === 'success') {
            location.reload();
        } else {
            alert('Error al actualizar cantidad: ' + data.message);
        }
    })
    .catch(error => {
        console.error('Error:', error);
        alert('Error al actualizar cantidad');
    });
}

function removeFromCart(productId) {
    if (confirm('¿Eliminar este producto del carrito?')) {
        fetch(`/api/carts/{{cart.id}}/products/${productId}`, {
            method: 'DELETE'
        })
        .then(response => response.json())
        .then(data => {
            if (data.status === 'success') {
                location.reload();
            } else {
                alert('Error al eliminar producto: ' + data.message);
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Error al eliminar producto');
        });
    }
}

function clearCart() {
    if (confirm('¿Vaciar todo el carrito?')) {
        fetch(`/api/carts/{{cart.id}}`, {
            method: 'DELETE'
        })
        .then(response => response.json())
        .then(data => {
            if (data.status === 'success') {
                location.reload();
            } else {
                alert('Error al vaciar carrito: ' + data.message);
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Error al vaciar carrito');
        });
    }
}
</script>

<style>
