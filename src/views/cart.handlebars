}

.empty-cart h2 {
    margin: 20px 0 10px;
    color: #333;
}

.empty-cart p {
    color: #666;
    margin-bottom: 30px;
}

.btn-shop {
    display: inline-block;
    background: #667eea;
    color: white;
    text-decoration: none;
    padding: 12px 30px;
    border-radius: 4px;
    transition: opacity 0.3s;
}

.btn-shop:hover {
    opacity: 0.8;
}

@media (max-width: 768px) {
    .cart-item {
        grid-template-columns: 1fr;
        text-align: center;
    }
    
    .item-image {
        margin: 0 auto;
    }
    
    .item-category {
